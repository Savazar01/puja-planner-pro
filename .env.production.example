# Production environment variables for Coolify deployment

# API Keys (REQUIRED)
SERPER_API_KEY=your_serper_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
GEMINI_API_KEY=<GEMINI_API_KEY>
RESEND_API_KEY=your_resend_api_key_here

# Database Configuration
DATABASE_URL=postgresql://puja_user:CHANGE_THIS_PASSWORD@postgres:5432/puja_planner
POSTGRES_PASSWORD=secure_password_here

# Admin Bootstrapping & Auth
ADMIN_USER=<ADMIN_USER>
ADMIN_PASSWORD=<ADMIN_PASSWORD>
SECRET_KEY=fallback_secret_key_changeme_in_prod

# Application Settings
ENVIRONMENT=production
DEBUG=False
CORS_ORIGINS=https://your-domain.com

# Cache Settings
CACHE_EXPIRY_HOURS=24

# Frontend
VITE_API_URL=https://api.your-domain.com
FRONTEND_PORT=8734

# Backend
BACKEND_PORT=8735

# Intelligence Stack
OLLAMA_BASE_URL=http://ollama-api:11434
OLLAMA_MODEL=your_ollama_model_here
EMBEDDING_MODEL=your_embedding_model_here
REDIS_URL=redis://redis:6379/0
